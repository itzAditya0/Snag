# snag api configuration. copy to .env to use.
# full reference: ../docs/api-env-variables.md

# REQUIRED: public URL the api advertises itself as.
# for local dev, use the listen URL. for production, use your reverse-proxy URL.
API_URL=http://localhost:9000

# port the api listens on. defaults to 9000.
API_PORT=9000

# CORS — for local dev, leave wildcard on so the web frontend can call the api.
# in production set CORS_URL to your specific frontend origin and CORS_WILDCARD=0.
CORS_WILDCARD=1
# CORS_URL=https://snag.example.com

# rate limiting (requests per window-seconds)
# RATELIMIT_WINDOW=60
# RATELIMIT_MAX=20
# TUNNEL_RATELIMIT_WINDOW=60
# TUNNEL_RATELIMIT_MAX=40

# JWT (only needed if you enable Turnstile / session auth)
# JWT_SECRET=run "pnpm --filter @snag/api token:jwt" to generate
# TURNSTILE_SITEKEY=
# TURNSTILE_SECRET=

# imgur API client id (free, register at https://api.imgur.com/oauth2/addclient)
# without this, snag falls back to probing direct media URLs for single posts.
# albums and galleries require a client id.
# IMGUR_CLIENT_ID=

# disable specific services (comma-separated)
# DISABLED_SERVICES=youtube,instagram

# IPv6 rotation for rate-limit evasion (Linux only, requires routed prefix)
# FREEBIND_CIDR=2001:db8::/48
